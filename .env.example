# ── Application Configuration ────────────────────────────────────────────────
APP_NAME=video-use-backend
DEBUG=false

# ── Security & Authentication ────────────────────────────────────────────────
# Set to 'true' in staging/production to lock down all upload and editing endpoints
AUTH_ENABLED=true

# CRITICAL: Always generate a cryptographically secure random secret key in production!
# You can generate one via: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_SECURE_RANDOM_HEX_SECRET_KEY

# ── Third-Party Integrations ─────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Network Hardening ────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
